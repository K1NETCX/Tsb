-- TSB SURF TECH - Ativa APENAS com a tecla R
-- Impulso manual para simular surf tech

if setfpscap then setfpscap(999999) end

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local player = Players.LocalPlayer

-- ========== CONFIGURAÇÕES ==========
local velocidade = 140     -- Velocidade do impulso
local altura = 30           -- Altura do pulo

-- ========== FUNÇÃO DO IMPULSO ==========
local function darImpulso()
    local char = player.Character
    if not char then 
        print("❌ Sem personagem")
        return 
    end

    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")

    if not root or not humanoid then 
        print("❌ Sem Root/Humanoid")
        return 
    end

    local camera = workspace.CurrentCamera
    local direction = camera.CFrame.LookVector
    direction = Vector3.new(direction.X, 0, direction.Z).Unit

    root.Velocity = direction * velocidade
    task.wait(0.05)
    root.Velocity = Vector3.new(root.Velocity.X, altura, root.Velocity.Z)

    print("💨 IMPULSO ATIVADO! (Tecla R)")
end

-- ========== DETECTA TECLA R ==========
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.E then
        darImpulso()
    end
end)

-- ========== INFINITE STAMINA ==========
local function infiniteStamina()
    local char = player.Character
    if char then
        local stamina = char:FindFirstChild("Stamina")
        if stamina then
            stamina:Destroy()
        end
    end
end

player.CharacterAdded:Connect(function(char)
    task.wait(1)
    infiniteStamina()
end)

infiniteStamina()

-- ========== TEXTO PERSONALIZADO (VERSÃO GARANTIDA) ==========
local function criarTexto()
    -- Cria o ScreenGui no CoreGui (sempre funciona)
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "SurfTechCredit"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = CoreGui

    -- Frame do texto
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 160, 0, 25)
    frame.Position = UDim2.new(0, 10, 1, -35)
    frame.BackgroundTransparency = 0.5
    frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    frame.BorderSizePixel = 0
    frame.Parent = screenGui

    -- Texto
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = "Made by FxLL3N4"
    text.TextColor3 = Color3.fromRGB(0, 0, 0)  -- Preto
    text.TextSize = 14
    text.Font = Enum.Font.GothamBold
    text.TextXAlignment = Enum.TextXAlignment.Center
    text.Parent = frame

    print("✅ Texto 'Made by FxLL3N4' criado no CoreGui")
end

-- Cria o texto imediatamente
criarTexto()

print("=" * 40)
print("🐺 SURF TECH ATIVADO!")
print("✅ Pressione R para dar o impulso")
print("⚡ Velocidade: " .. velocidade)
print("📝 Made by FxLL3N4 no canto inferior esquerdo")
